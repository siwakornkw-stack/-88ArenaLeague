// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  TEAM_MANAGER
}

enum LeagueStatus {
  DRAFT
  SCHEDULED
  IN_PROGRESS
  FINISHED
}

enum MatchStatus {
  SCHEDULED
  LIVE
  FINISHED
}

enum PlayerStatus {
  ACTIVE
  INJURED
  BANNED
}

enum EventType {
  KICK_OFF
  GOAL
  YELLOW_CARD
  RED_CARD
  SUBSTITUTION
  HALF_TIME
  FULL_TIME
}

enum Side {
  HOME
  AWAY
  NEUTRAL
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role
  managedTeams Team[]   @relation("TeamManagers")
  createdAt    DateTime @default(now())
}

model League {
  id        String       @id @default(cuid())
  name      String
  seasonYear Int
  type      String
  legs      Int          @default(1)
  status    LeagueStatus @default(DRAFT)
  createdAt DateTime     @default(now())
  teams     Team[]
  matches   Match[]
}

model Team {
  id        String   @id @default(cuid())
  name      String
  abbr      String
  color     String   @default("#2E5CB8")
  league    League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  leagueId  String
  managers  User[]   @relation("TeamManagers")
  players   Player[]
  homeMatches Match[] @relation("HomeTeam")
  awayMatches Match[] @relation("AwayTeam")
  createdAt DateTime @default(now())
}

model Player {
  id        String       @id @default(cuid())
  name      String
  number    Int
  position  String
  status    PlayerStatus @default(ACTIVE)
  team      Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId    String
  events    MatchEvent[]
  relatedEvents MatchEvent[] @relation("RelatedPlayerEvents")
  lineups   MatchLineup[]
  createdAt DateTime     @default(now())

  @@unique([teamId, number])
}

model Match {
  id         String        @id @default(cuid())
  league     League        @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  leagueId   String
  round      Int
  homeTeam   Team          @relation("HomeTeam", fields: [homeTeamId], references: [id])
  homeTeamId String
  awayTeam   Team          @relation("AwayTeam", fields: [awayTeamId], references: [id])
  awayTeamId String
  kickoffAt  DateTime
  venue      String?
  status     MatchStatus   @default(SCHEDULED)
  homeScore  Int           @default(0)
  awayScore  Int           @default(0)
  minute     Int           @default(0)
  homePossession     Int   @default(50)
  awayPossession     Int   @default(50)
  homeShots          Int   @default(0)
  awayShots          Int   @default(0)
  homeShotsOnTarget  Int   @default(0)
  awayShotsOnTarget  Int   @default(0)
  homeCorners        Int   @default(0)
  awayCorners        Int   @default(0)
  homeFouls          Int   @default(0)
  awayFouls          Int   @default(0)
  events     MatchEvent[]
  lineups    MatchLineup[]
  createdAt  DateTime      @default(now())
}

model MatchEvent {
  id        String    @id @default(cuid())
  match     Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)
  matchId   String
  minute    Int
  label     String
  type      EventType
  side      Side
  player    Player?   @relation(fields: [playerId], references: [id])
  playerId  String?
  relatedPlayer   Player? @relation("RelatedPlayerEvents", fields: [relatedPlayerId], references: [id])
  relatedPlayerId String?
  createdAt DateTime  @default(now())
}

model MatchLineup {
  id         String  @id @default(cuid())
  match      Match   @relation(fields: [matchId], references: [id], onDelete: Cascade)
  matchId    String
  player     Player  @relation(fields: [playerId], references: [id], onDelete: Cascade)
  playerId   String
  isStarting Boolean @default(true)

  @@unique([matchId, playerId])
}
